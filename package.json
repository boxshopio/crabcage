{
  "name": "@crabcage/cli",
  "version": "0.1.2",
  "description": "An auditable sandbox for agent harnesses",
  "type": "module",
  "bin": {
    "crabcage": "./dist/cli.js"
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=22"
  },
  "keywords": [
    "sandbox",
    "ai",
    "agent",
    "claude",
    "docker",
    "security",
    "audit"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/boxshopio/crabcage"
  },
  "dependencies": {
    "ajv": "^8.18.0",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "execa": "^9.6.1",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.1"
  }
}
